{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Love2D: Run project",
            "type": "shell",
            "command": "${workspaceFolder}/love-11.5-win64/lovec.exe",
            "args": [
                "${workspaceFolder}/project/src"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Love2D: Run project (Global)",
            "type": "shell",
            "command": "love",
            "args": [
                "${workspaceFolder}/project/src"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run run.bat",
            "type": "shell",
            "command": "${workspaceFolder}/run.bat",
            "problemMatcher": []
        },
        {
            "label": "Lua: Run current file",
            "type": "shell",
            "command": "lua",
            "args": [
                "${file}"
            ],
            "problemMatcher": []
        }
    ]
}